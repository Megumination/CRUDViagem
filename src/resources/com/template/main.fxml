<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">
    <children>
      <Pane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #9abad9;">
         <children>
            <Button fx:id="btnExcluir" layoutX="446.0" layoutY="116.0" mnemonicParsing="false" onAction="#btnExcluirAction" prefHeight="30.0" prefWidth="78.0" style="-fx-background-color: #bf6d3d;" text="Excluir" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Button>
            <Button fx:id="btnAlterar" layoutX="446.0" layoutY="76.0" mnemonicParsing="false" onAction="#btnAlterarAction" prefHeight="30.0" prefWidth="78.0" style="-fx-background-color: #bf6d3d;" text="Alterar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Button>
              <Button fx:id="btnCadastrar" layoutX="445.0" layoutY="36.0" mnemonicParsing="false" onAction="#btnCadastrarAction" prefHeight="30.0" prefWidth="78.0" style="-fx-background-color: #bf6d3d;" text="Cadastrar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Button>
            <Label layoutX="60.0" layoutY="73.0" text="Destino" />
            <Label layoutX="270.0" layoutY="73.0" text="Preço" />
            <Label layoutX="60.0" layoutY="131.0" prefHeight="17.0" prefWidth="99.0" text="Data de ida" />
            <Label layoutX="145.0" layoutY="131.0" text="Data de volta" />
            <TextField fx:id="txtDestino" layoutX="60.0" layoutY="93.0" prefHeight="25.0" prefWidth="155.0" style="-fx-background-color: #ffffff;" />
            <TableView fx:id="tblViagem" layoutX="60.0" layoutY="200.0" onMouseClicked="#carregarCampos" prefHeight="200.0" prefWidth="465.0" style="-fx-background-color: #d6ebff;">
              <columns>
                <TableColumn fx:id="colID" prefWidth="41.0" text="ID" />
                <TableColumn fx:id="colDestino" prefWidth="83.0" text="Destino" />
                  <TableColumn fx:id="colPreco" prefWidth="68.0" text="Preço" />
                  <TableColumn fx:id="colDataIda" prefWidth="92.0" text="Data de Ida" />
                  <TableColumn fx:id="colDataVolta" prefWidth="94.0" text="Data de Volta" />
                  <TableColumn fx:id="colObservacoes" prefWidth="86.0" text="Observações" />
              </columns>
            </TableView>
            <TextField fx:id="txtPreco" layoutX="270.0" layoutY="93.0" prefHeight="25.0" prefWidth="149.0" style="-fx-background-color: #ffffff;" />
            <TextField fx:id="txtObservacoes" layoutX="270.0" layoutY="151.0" style="-fx-background-color: #ffffff;" />
            <Label layoutX="270.0" layoutY="131.0" prefHeight="17.0" prefWidth="99.0" text="Observações" />
            <Button fx:id="btnLimpar" layoutX="446.0" layoutY="155.0" mnemonicParsing="false" onAction="#btnLimparAction" prefHeight="30.0" prefWidth="78.0" style="-fx-background-color: #bf6d3d;" text="Limpar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <DatePicker fx:id="dtpDataIda" layoutX="60.0" layoutY="151.0" prefHeight="25.0" prefWidth="70.0" />
            <DatePicker fx:id="dtpDataVolta" layoutX="145.0" layoutY="151.0" prefHeight="25.0" prefWidth="70.0" />
            <Label layoutX="60.0" layoutY="25.0" text="Cadastro de Viagens" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
         </children>
      </Pane>
    </children>
</AnchorPane>
